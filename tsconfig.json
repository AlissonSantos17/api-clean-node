{
    "compilerOptions": {
        "target": "ES2024",
        "module": "CommonJS",
        "rootDir": "src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "allowJs": true,
        "strict": true,
        "sourceMap": true,
        "incremental": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo",
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "**/*.spec.ts", "**/*.test.ts"],
}