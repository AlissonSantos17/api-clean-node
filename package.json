{
  "name": "clean-node-api",
  "version": "1.2.0",
  "packageManager": "yarn@1.22.22",
  "main": "dist/main/server.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/main/server.js",
    "debug": "node --inspect=0.0.0.0:9222 --nolazy dist/main/server.js",
    "up": "yarn build && docker compose up -d --build",
    "down": "docker compose down",
    "start:prod": "node dist/main/server.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "test": "jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "jest --passWithNoTests",
    "test:unit": "yarn test --watch -c jest-unit.config.ts",
    "test:integration": "yarn test --watch -c jest-integration.config.ts",
    "test:staged": "yarn test --findRelatedTests",
    "test:ci": "yarn test --coverage"
  },
  "engines": {
    "node": ">=22.x"
  },
  "author": "Alisson Santos <alisson.wiin@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@shelf/jest-mongodb": "^6.0.2",
    "@swc/core": "^1.15.18",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.1",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "eslint": "^9.35.0",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "git-commit-msg-linter": "^5.0.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "validator": "^13.15.26"
  }
}
