{
  "name": "clean-node-api",
  "version": "1.1.0",
  "packageManager": "yarn@4.13.0",
  "main": "dist/main/server.js",
  "scripts": {
    "build": "tsc",
    "start": "sucrase-node src/main/server.ts",
    "dev": " yarn build && yarn start",
    "start:prod": "node dist/main/server.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "test": "jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "jest --passWithNoTests",
    "test:unit": "yarn test --watch -c jest-unit.config.ts",
    "test:integration": "yarn test --watch -c jest-integration.config.ts",
    "test:staged": "yarn test --findRelatedTests",
    "test:ci": "yarn test --coverage"
  },
  "author": "Alisson Santos <alisson.wiin@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@shelf/jest-mongodb": "^6.0.2",
    "@swc/core": "^1.15.18",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.1",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "eslint": "^9.35.0",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "git-commit-msg-linter": "^5.0.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sucrase": "^3.35.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "validator": "^13.15.26"
  }
}
